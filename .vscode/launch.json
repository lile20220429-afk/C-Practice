{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "调试 C/C++ 程序",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/../build/program.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: 编译"
        },

    ]
}